  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "jwt",
      "value": "",
      "type": "string",
      "description": "Set this after running Login"
    },
    {
      "key": "demoResetSecret",
      "value": "dev-demo-secret-2026",
      "type": "string"
    },
    {
      "key": "id",
      "value": "1",
      "type": "string",
      "description": "Generic resource ID"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-save JWT from login response",
          "if (pm.info.requestName === 'Login' && pm.response.code === 200) {",
          "  const body = pm.response.json();",
          "  if (body.token) { pm.collectionVariables.set('jwt', body.token); }",
          "}"
        ]
      }
    }
  ],
