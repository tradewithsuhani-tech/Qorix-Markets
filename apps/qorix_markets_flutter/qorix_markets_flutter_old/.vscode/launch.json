{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Qorix Markets (staging + Google)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define-from-file=dart_defines.json"
      ]
    },
    {
      "name": "Qorix Markets (staging, no defines file)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=ENV=staging"
      ]
    }
  ]
}
