{
  "id": "/",
  "name": "Qorix Markets",
  "short_name": "Qorix",
  "description": "Professional automated USDT trading platform. Invest, grow, and track your portfolio.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone", "minimal-ui", "browser"],
  "orientation": "portrait-primary",
  "background_color": "#0a0f1c",
  "theme_color": "#3b82f6",
  "categories": ["finance", "business"],
  "lang": "en",
  "dir": "ltr",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "View your trading dashboard",
      "url": "/dashboard",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Wallet",
      "short_name": "Wallet",
      "description": "Manage your wallet",
      "url": "/wallet",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-wide-1280x720.jpg",
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Qorix Markets Trading Dashboard"
    },
    {
      "src": "/screenshot-narrow-750x1334.jpg",
      "sizes": "750x1334",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Qorix Markets Mobile Experience"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "handle_links": "preferred",
  "scope_extensions": [
    { "origin": "https://*.qorixmarkets.com" }
  ],
  "widgets": [
    {
      "name": "Portfolio Snapshot",
      "short_name": "Portfolio",
      "description": "Quick view of your Qorix portfolio balance and today's P/L.",
      "tag": "portfolio-snapshot",
      "ms_ac_template": "/widgets/portfolio-template.json",
      "data": "/widgets/portfolio-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/screenshot-narrow-750x1334.jpg",
          "sizes": "750x1334",
          "label": "Portfolio widget preview"
        }
      ],
      "icons": [
        { "src": "/icon-192.png", "sizes": "192x192" }
      ],
      "auth": false,
      "update": 900
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "file_handlers": [
    {
      "action": "/transactions/import",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"]
      },
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+qorix",
      "url": "/?action=%s"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.qorixmarkets.app",
      "id": "com.qorixmarkets.app"
    }
  ]
}
